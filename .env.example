# AI Agent CRUD - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# AI Provider API Keys (at least one required)
# ============================================

# OpenAI API Key - Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key - Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Groq API Key - Get from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API Key - Get from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# NVIDIA API Key - Get from https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# Together AI API Key - Get from https://api.together.xyz/
TOGETHER_API_KEY=your_together_api_key_here

# Mistral AI API Key - Get from https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Cohere API Key - Get from https://cohere.com/
COHERE_API_KEY=your_cohere_api_key_here

# ============================================
# Security Settings
# ============================================

# Maximum file size in MB (default: 10)
MAX_FILE_SIZE_MB=10

# Allowed file extensions (comma-separated, no spaces)
ALLOWED_EXTENSIONS=.txt,.json,.yaml,.yml,.md,.csv,.py,.js,.html,.css,.xml,.log

# Blocked file extensions (comma-separated, no spaces)
BLOCKED_EXTENSIONS=.exe,.dll,.so,.dylib,.bat,.sh,.ps1,.app,.deb,.rpm

# Blocked path patterns (semicolon-separated)
BLOCKED_PATTERNS=..;~;/etc;/sys;/proc;C:\\Windows;C:\\Program Files;/bin;/sbin;/usr/bin

# ============================================
# Timeout Settings
# ============================================

# Command execution timeout in seconds (default: 30)
COMMAND_TIMEOUT_SECONDS=30

# API request timeout in seconds (default: 120)
API_TIMEOUT_SECONDS=120

# API request retry timeout in seconds (default: 10)
API_RETRY_TIMEOUT_SECONDS=10

# ============================================
# Conversation Settings
# ============================================

# Maximum conversation history messages (default: 20)
MAX_CONVERSATION_MESSAGES=20

# Maximum tool execution iterations (default: 5)
MAX_TOOL_ITERATIONS=5

# ============================================
# Logging Settings
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Enable audit logging (default: true)
ENABLE_AUDIT_LOGGING=true

# ============================================
# Advanced Settings
# ============================================

# Base directory for operations (default: current working directory)
# BASE_DIR=/path/to/workspace

# Custom configuration file path (default: config.yaml)
# CONFIG_PATH=/path/to/config.yaml

# Enable debug mode (default: false)
DEBUG=false
